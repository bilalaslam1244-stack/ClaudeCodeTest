TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Optional: local Bot API server URL (removes 20MB file limit)
# TELEGRAM_LOCAL_API_URL=http://localhost:8081/bot
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ALLOWED_USER_ID=123456789
BOSS_TIMEZONE=Asia/Kuala_Lumpur
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001
CLAUDE_SONNET_MODEL=claude-sonnet-4-6
GOOGLE_CREDENTIALS_PATH=data/credentials.json
GOOGLE_TOKEN_PATH=data/token.json
DB_PATH=data/pa.db

# Optional: Zoom integration (auto-creates Zoom meeting when scheduling calendar events)
# Get these from https://marketplace.zoom.us → Build App → Server-to-Server OAuth
# ZOOM_ACCOUNT_ID=your_zoom_account_id
# ZOOM_CLIENT_ID=your_zoom_client_id
# ZOOM_CLIENT_SECRET=your_zoom_client_secret

# Optional: Flight search via Amadeus (free 2000 searches/month)
# Get keys at https://developers.amadeus.com → My Apps → Create App
# After testing works, change AMADEUS_BASE_URL to https://api.amadeus.com for live data
# AMADEUS_API_KEY=your_amadeus_api_key
# AMADEUS_API_SECRET=your_amadeus_api_secret
# AMADEUS_BASE_URL=https://test.api.amadeus.com
